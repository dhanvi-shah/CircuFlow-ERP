<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Resolve model_id by technical name so upgrade works even if ir.model.data xmlids are missing. -->
    <record id="access_pickup_request_user" model="ir.model.access">
        <field name="name">pickup.request.user</field>
        <field name="model_id" model="ir.model" search="[('model', '=', 'pickup.request')]"/>
        <field name="group_id" ref="base.group_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
