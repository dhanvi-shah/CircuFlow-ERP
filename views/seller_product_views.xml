<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_seller_product_list" model="ir.ui.view">
        <field name="name">recycle.seller.product.list</field>
        <field name="model">recycle.seller.product</field>
        <field name="arch" type="xml">
            <list string="Seller Products" decoration-success="eco_friendly">
                <field name="product_name"/>
                <field name="seller_name"/>
                <field name="price"/>
                <field name="quantity_available"/>
                <field name="eco_friendly" string="Eco" widget="boolean" optional="show"/>
                <field name="category_ids" widget="many2many_tags" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_seller_product_form" model="ir.ui.view">
        <field name="name">recycle.seller.product.form</field>
        <field name="model">recycle.seller.product</field>
        <field name="arch" type="xml">
            <form string="Seller Product">
                <sheet>
                    <div class="oe_title">
                        <label for="product_name"/>
                        <h1>
                            <field name="product_name" placeholder="Product name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Seller">
                            <field name="seller_name"/>
                            <field name="eco_friendly" widget="boolean_toggle"/>
                        </group>
                        <group string="Pricing &amp; stock">
                            <field name="price"/>
                            <field name="quantity_available"/>
                        </group>
                    </group>
                    <group string="Categories">
                        <field
                            name="category_ids"
                            widget="many2many_tags"
                            placeholder="Add categories..."
                        />
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Product details..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_seller_product_search" model="ir.ui.view">
        <field name="name">recycle.seller.product.search</field>
        <field name="model">recycle.seller.product</field>
        <field name="arch" type="xml">
            <search string="Seller Products">
                <field name="product_name"/>
                <field name="seller_name"/>
                <field name="category_ids"/>
                <filter string="In stock" name="filter_in_stock" domain="[('quantity_available', '&gt;', 0)]"/>
                <filter string="Out of stock" name="filter_out_of_stock" domain="[('quantity_available', '&lt;=', 0)]"/>
                <filter string="Eco-friendly" name="eco" domain="[('eco_friendly', '=', True)]"/>
                <separator/>
                <group>
                    <filter string="Eco-friendly" name="group_eco" domain="[]" context="{'group_by': 'eco_friendly'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
