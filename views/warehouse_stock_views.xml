<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_warehouse_stock_list" model="ir.ui.view">
        <field name="name">warehouse.stock.list</field>
        <field name="model">warehouse.stock</field>
        <field name="arch" type="xml">
            <list string="Warehouse Stock">
                <field name="warehouse_name"/>
                <field name="waste_type"/>
                <field name="quantity_available"/>
            </list>
        </field>
    </record>

    <record id="view_warehouse_stock_kanban" model="ir.ui.view">
        <field name="name">warehouse.stock.kanban</field>
        <field name="model">warehouse.stock</field>
        <field name="arch" type="xml">
            <kanban default_group_by="waste_type" group_create="0">
                <field name="warehouse_name"/>
                <field name="waste_type"/>
                <field name="quantity_available"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-3 border rounded-2">
                            <div class="fw-bold fs-5 mb-1">
                                <field name="warehouse_name"/>
                            </div>
                            <div class="text-muted small mb-2">
                                <field name="waste_type"/>
                            </div>
                            <div class="d-flex align-items-baseline gap-2">
                                <span class="text-muted">Quantity</span>
                                <field name="quantity_available" class="fw-semibold"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_warehouse_stock_form" model="ir.ui.view">
        <field name="name">warehouse.stock.form</field>
        <field name="model">warehouse.stock</field>
        <field name="arch" type="xml">
            <form string="Warehouse Stock">
                <sheet>
                    <group>
                        <field name="warehouse_name"/>
                        <field name="waste_type"/>
                        <field name="quantity_available"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_warehouse_stock_search" model="ir.ui.view">
        <field name="name">warehouse.stock.search</field>
        <field name="model">warehouse.stock</field>
        <field name="arch" type="xml">
            <search string="Warehouse Stock">
                <field name="warehouse_name"/>
                <field name="waste_type"/>
                <separator/>
                <group>
                    <filter string="Warehouse" name="group_wh" domain="[]" context="{'group_by': 'warehouse_name'}"/>
                    <filter string="Waste Type" name="group_waste" domain="[]" context="{'group_by': 'waste_type'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
