<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_recycle_dashboard_form" model="ir.ui.view">
        <field name="name">recycle.dashboard.form</field>
        <field name="model">recycle.dashboard</field>
        <field name="arch" type="xml">
            <form string="CircuFlow Dashboard" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <h1>CircuFlow ERP</h1>
                        <p class="text-muted">Recycling coordination and marketplace overview.</p>
                    </div>
                    <group>
                        <group string="Recycling">
                            <field name="pickup_total" readonly="1"/>
                            <field name="pickup_pending" readonly="1"/>
                        </group>
                        <group string="Agencies">
                            <field name="agency_total" readonly="1"/>
                            <field name="agency_requested" readonly="1"/>
                        </group>
                        <group string="Warehouse">
                            <field name="warehouse_total" readonly="1"/>
                            <field name="warehouse_stock_qty" readonly="1"/>
                        </group>
                        <group string="Marketplace">
                            <div class="text-muted" colspan="2">
                                Open <strong>Seller Products</strong> and <strong>Buyers</strong> from the top-level menu.
                            </div>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
