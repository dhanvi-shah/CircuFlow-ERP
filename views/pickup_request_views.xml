<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pickup_request_list" model="ir.ui.view">
        <field name="name">pickup.request.list</field>
        <field name="model">pickup.request</field>
        <field name="arch" type="xml">
            <list
                string="Pickup Requests"
                decoration-success="status == 'completed'"
                decoration-warning="status == 'pending'"
                decoration-info="status == 'assigned'"
                decoration-danger="status == 'cancelled'"
            >
                <field name="name"/>
                <field name="location"/>
                <field name="waste_type"/>
                <field name="quantity"/>
                <field name="date"/>
                <field name="status" optional="show"/>
                <button name="action_assign" type="object" string="Assign" class="btn-link" invisible="status != 'pending'"/>
                <button name="action_complete" type="object" string="Complete" class="btn-link" invisible="status != 'assigned'"/>
                <button name="action_cancel" type="object" string="Cancel" class="btn-link" invisible="status in ('completed', 'cancelled')"/>
            </list>
        </field>
    </record>

    <record id="view_pickup_request_form" model="ir.ui.view">
        <field name="name">pickup.request.form</field>
        <field name="model">pickup.request</field>
        <field name="arch" type="xml">
            <form string="Pickup Request">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="pending,assigned,completed,cancelled"/>
                    <button name="action_assign" type="object" string="Assign" class="oe_highlight" invisible="status != 'pending'"/>
                    <button name="action_complete" type="object" string="Complete" class="oe_highlight" invisible="status != 'assigned'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="status in ('completed', 'cancelled')"/>
                </header>
                <sheet>
                    <group>
                        <group string="Donor">
                            <field name="name"/>
                            <field name="location"/>
                        </group>
                        <group string="Waste">
                            <field name="waste_type"/>
                            <field name="quantity"/>
                            <field name="date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pickup_request_search" model="ir.ui.view">
        <field name="name">pickup.request.search</field>
        <field name="model">pickup.request</field>
        <field name="arch" type="xml">
            <search string="Pickup Requests">
                <field name="name"/>
                <field name="location"/>
                <field name="waste_type"/>
                <filter string="Pending" name="pending" domain="[('status', '=', 'pending')]"/>
                <filter string="Assigned" name="assigned" domain="[('status', '=', 'assigned')]"/>
                <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
                <separator/>
                <group>
                    <filter string="Status" name="group_status" domain="[]" context="{'group_by': 'status'}"/>
                    <filter string="Waste Type" name="group_waste" domain="[]" context="{'group_by': 'waste_type'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
